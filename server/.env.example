# Copy this file to .env and fill in real values for production.
# Anything left blank falls back to safe dev defaults.

# --- Server ---
NODE_ENV=development
PORT=4000

# --- JWT ---
# In production, set a long random string. Default dev secret is unsafe.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- The Odds API ---
ODDS_API_KEY=f29329416dc60d4defee32c746c2f9e2

# --- Email (SMTP) ---
# If SMTP_HOST is unset, OTP emails are printed to the server console (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Xenbet <no-reply@xenbet.gh>"

# --- Google OAuth ---
# Get these from https://console.cloud.google.com/apis/credentials
# Authorized JS origin: http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Rate limiting ---
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_OTP_MAX=3
