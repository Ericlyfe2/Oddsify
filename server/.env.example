# Copy this file to .env and fill in real values for production.
# Anything left blank falls back to safe dev defaults.

# --- Server ---
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed frontend origins (for CORS) when NODE_ENV=production.
# Example: https://oddsify-client.vercel.app,https://www.example.com
CORS_ORIGIN=

# Optional: name of a Vercel project whose preview deployments should also be
# trusted. When set, the server accepts any origin matching
#   https://<project>.vercel.app  OR  https://<project>-*.vercel.app
# so per-commit / per-branch Vercel previews work without re-listing every URL.
# Leave unset if you're not deploying to Vercel.
CORS_ALLOW_VERCEL=

# --- Admin accounts ---
# On first boot, the server seeds admin accounts. Passwords are randomly
# generated if not set here. The super_admin password can be set via
# ADMIN_PASSWORD; other roles have their own env vars below.
# Leave unset to use auto-generated passwords (printed once on boot).
ADMIN_PASSWORD=
FINANCE_ADMIN_PASSWORD=
ODDS_ADMIN_PASSWORD=
SUPPORT_ADMIN_PASSWORD=
MOD_ADMIN_PASSWORD=

# --- JWT ---
# In production, set a long random string (32+ chars). Default dev secret is unsafe.
JWT_SECRET=change-me-to-a-long-random-string
# Long-lived "always logged in" defaults. Refresh tokens are rotated on every
# refresh call, so an active user effectively never has to re-authenticate.
# Tighten for staff / shared devices if needed.
JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=3650d

# --- The Odds API ---
# Get a key from https://the-odds-api.com/. Leave blank to disable.
ODDS_API_KEY=
# Hard ceiling on outbound the-odds-api calls per UTC day. Free plan is
# 500/month (~16/day). Each fetch hits 3 sport keys (EPL + UCL + La Liga),
# so a budget of 15 yields ~5 cycles/day = ~450/month with safety margin.
# Leave blank to use the safe default (15) or override on a paid plan.
ODDS_API_DAILY_BUDGET=

# --- Email (SMTP) ---
# If SMTP_HOST is unset, OTP emails are printed to the server console (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Oddsify <no-reply@oddsify.gh>"

# --- Google OAuth ---
# Get these from https://console.cloud.google.com/apis/credentials
# Authorized JS origin: http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Rate limiting ---
# Global: 100 req/min per IP (skips /api/health).
RATE_LIMIT_GLOBAL_MAX=100
# Login: 5 attempts per 15 min per IP+email.
RATE_LIMIT_LOGIN_MAX=5
# OTP: 3 attempts per window per IP+email.
RATE_LIMIT_OTP_MAX=3

# Live betting
# API Football key. Two sources accepted:
#   1. Direct from api-football.com  → host stays as the default
#   2. RapidAPI marketplace key       → set APIFOOTBALL_HOST=api-football-v1.p.rapidapi.com
APIFOOTBALL_KEY=
APIFOOTBALL_HOST=v3.football.api-sports.io
# Hard ceiling on outbound api-football calls per UTC day. Free plan = 100.
# Leave blank to use the safe default (90) or override to your real plan limit.
APIFOOTBALL_DAILY_BUDGET=

# football-data.org v4 token. Free tier covers Premier League, La Liga,
# Serie A, Bundesliga, Ligue 1, UCL, EURO, WC — 10 req/min. Sign up at
# https://www.football-data.org/client/register. Note: ODDS are a paid
# add-on; this token only powers fixtures + live scores.
FOOTBALL_DATA_TOKEN=

# SportMonks v3 token (sportmonks.com/settings/tokens). Free tier coverage
# is limited (typically DK Superliga + SCO Premiership) — top-5 leagues
# require a paid subscription.
SPORTMONKS_TOKEN=

# RapidAPI Free Live Football Data (free-api-live-football-data.p.rapidapi.com).
# Get a key from https://rapidapi.com/ . Live scores only, no odds.
RAPIDAPI_FOOTBALL_KEY=
RAPIDAPI_FOOTBALL_HOST=free-api-live-football-data.p.rapidapi.com

# Live track cadence in ms. 20000 (20s) is recommended on Free-plan keys.
# Drop to 6000 only when every enabled provider is on a paid tier.
LIVE_POLL_MS=20000
CASHOUT_HOUSE_MARGIN=0.05
CASHOUT_DRIFT_TOLERANCE=0.01
